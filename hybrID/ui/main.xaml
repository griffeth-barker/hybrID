<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="hybrID" 
        Height="530" Width="650" 
        Background="{DynamicResource WindowBg}" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,3"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,8"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Identity" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"/>
                
                <Border Width="18" Height="18" CornerRadius="9" Background="#007ACC" Margin="10,0,0,0" Cursor="Help" ToolTip="Acceptable Formats:&#x0a;• sAMAccountName (e.g., jsmith)&#x0a;• UPN (e.g., jsmith@domain.com)&#x0a;• ObjectGUID (e.g., 12345678-1234-...)">
                    <TextBlock Text="i" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                </Border>
            </StackPanel>
            
            <Grid Grid.Row="1" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSearch" Grid.Column="0" Margin="0,0,15,0" VerticalContentAlignment="Center"/>
                <Button x:Name="btnSearch" Grid.Column="1" Content="Locate" Width="130"/>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Object Name" Margin="0,0,0,15"/>
                    <TextBox x:Name="valName" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,15" Background="{DynamicResource WindowBg}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Object Class" Margin="0,0,0,15"/>
                    <TextBox x:Name="valClass" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,15" Background="{DynamicResource WindowBg}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Notes" VerticalAlignment="Top" Margin="0,5,0,15"/>
                    <TextBox x:Name="valNotes" Grid.Row="2" Grid.Column="1" IsReadOnly="True" TextWrapping="Wrap" Background="{DynamicResource WindowBg}" Foreground="{DynamicResource NotesText}" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Identity Management" Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtManageIdentity" Grid.Row="3" Grid.Column="1" Margin="5,0,0,15" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Mail Management" Margin="0,0,0,0"/>
                    <TextBlock x:Name="txtManageExchange" Grid.Row="4" Grid.Column="1" Margin="5,0,0,0" />
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="1" x:Name="statusBar" Background="#007ACC" Foreground="#FFFFFF" Padding="5,2">
            <StatusBarItem DockPanel.Dock="Right" Margin="0,0,5,0">
                <Button x:Name="btnAbout" ToolTip="About hybrID" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#FFFFFF" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StatusBarItem>
            
            <StatusBarItem DockPanel.Dock="Right" Margin="0,0,10,0">
                <Button x:Name="btnSettings" ToolTip="Settings &amp; Configuration" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#FFFFFF" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StatusBarItem>
            
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Initializing..." Foreground="#FFFFFF" FontSize="12" FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>