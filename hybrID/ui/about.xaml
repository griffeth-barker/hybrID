<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="250" Width="380" Background="{DynamicResource PanelBg}" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI" ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="hybrID v0.1.0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Griffeth Barker 2026" FontSize="14" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Open Source under the MIT license" FontSize="14" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <TextBlock HorizontalAlignment="Center" FontSize="14">
                <Hyperlink x:Name="lnkGitHub" NavigateUri="https://github.com/griffeth-barker/hybrID" TextDecorations="Underline">
                    https://github.com/griffeth-barker/hybrID
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <Button x:Name="btnClose" Grid.Row="1" Content="Close" HorizontalAlignment="Center" Background="#007ACC" Foreground="#FFFFFF" Padding="25,8" BorderThickness="0" Cursor="Hand" Margin="0,15,0,0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,6"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>